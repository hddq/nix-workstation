{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "timezone": "Europe/Warsaw",
  "schedule": ["after 10pm"],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchPackageNames": ["nixpkgs", "nixos-unstable"],
      "groupName": "nixpkgs system updates",
      "recreateClosed": false
    }
  ]
}