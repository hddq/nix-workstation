{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 10pm"] 
  },
  "packageRules": [
    {
      "matchPackageNames": ["nixpkgs", "nixos-unstable"],
      "groupName": "nixpkgs system updates"
    }
  ]
}